# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/machinesearch

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string

# ── Scraper behaviour ────────────────────────────────────────────────────────
SCRAPE_INTERVAL_HOURS=6
MAX_WORKERS=10
PLAYWRIGHT_ENABLED=false

# ── Bright Data proxy ────────────────────────────────────────────────────────
BRIGHT_DATA_HOST=
BRIGHT_DATA_PORT=
BRIGHT_DATA_USER=
BRIGHT_DATA_PASS=

# ── 2captcha ─────────────────────────────────────────────────────────────────
TWOCAPTCHA_API_KEY=

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Admin bootstrap account ───────────────────────────────────────────────────
ADMIN_EMAIL=
ADMIN_PASSWORD=
