{
  "name": "used_machines",
  "display_name": "Used-Machines.com",
  "start_url": "https://www.used-machines.com/k/gmcp-cat-2",
  "language": "en",
  "pagination": true,
  "pagination_type": "page_param",
  "pagination_param": "page",
  "max_pages": 8,
  "detail_page": false,
  "mode": "static",
  "proxy_tier": "none",
  "rate_limit_delay": 2,
  "enabled": true,
  "base_url": "https://www.used-machines.com",
  "selectors": {
    "listing_container": "section.grid-card",
    "name": "a[data-grid='title'] h2, a[data-grid='title'] .h5",
    "price": "div.price div.h4, div[data-grid='price'] .h4",
    "image": "div.keen-slider__slide.active img.first-image, img.first-image",
    "location": "div.country-name",
    "detail_link": "a[data-grid='title']",
    "next_page": "a[rel=next], li.next a"
  },
  "fields": ["name", "price", "brand", "image", "location", "description", "specs"]
}
