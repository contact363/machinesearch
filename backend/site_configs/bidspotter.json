{
  "name": "bidspotter",
  "display_name": "BidSpotter",
  "start_url": "https://www.bidspotter.com/en-us/for-sale/metalworking/machine-tools-and-tools",
  "language": "en",
  "pagination": true,
  "pagination_type": "page_param",
  "pagination_param": "page",
  "max_pages": 90,
  "detail_page": false,
  "mode": "static",
  "proxy_tier": "none",
  "rate_limit_delay": 2,
  "enabled": true,
  "base_url": "https://www.bidspotter.com",
  "selectors": {
    "listing_container": "div.lot-single",
    "name": "div.main div.lot-header h3 a, div.main h3 a, div.main .lot-title",
    "price": "li.current-price .price-value, li.opening-price .price-value, li.current-price, li.opening-price",
    "image": "div.thumb img.deferred-load",
    "location": "div.lotlocationDiv, div.byline.client-url a",
    "detail_link": "div.main div.lot-header h3 a, div.main a.lot-link",
    "next_page": "a[rel=next], li.next a"
  },
  "fields": ["name", "price", "brand", "image", "location", "description", "specs"],
  "_note": "5095 items / 60 per page ~= 85 pages. ?page=N confirmed working."
}
